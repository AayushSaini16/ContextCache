# Postgres shared with the ContextCache dashboard
DATABASE_URL=postgres://postgres:password@db.host:5432/postgres

# Redis for exact caching
REDIS_URL=redis://redis:6379/0

# Provider keys (server-side)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Embedding config (dim must match DB vector column: 1536)
EMBEDDING_MODEL=text-embedding-3-small

LOG_LEVEL=INFO
CORS_ORIGINS=*
